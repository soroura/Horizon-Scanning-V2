<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Horizon Scan — {{ run_date }}</title>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js"></script>
  <style>
    :root {
      --act-now: #FF4444; --watch: #FF8C00; --monitor: #FFD700;
      --awareness: #90EE90; --low: #D3D3D3; --bg: #f5f7fa; --card: #fff;
      --hdr: #2c3e50; --txt: #333;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
           background: var(--bg); color: var(--txt); }
    header { background: var(--hdr); color: #fff; padding: 16px 24px; }
    header h1 { font-size: 1.4rem; }
    header p  { font-size: 0.85rem; opacity: 0.8; }
    .container { max-width: 1400px; margin: 0 auto; padding: 20px; }
    .summary-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 12px; margin-bottom: 24px; }
    .metric-card { background: var(--card); border-radius: 8px; padding: 16px;
                   text-align: center; box-shadow: 0 1px 4px rgba(0,0,0,.08); }
    .metric-card .num { font-size: 2rem; font-weight: bold; }
    .metric-card .lbl { font-size: 0.8rem; opacity: 0.7; }
    .two-col { display: grid; grid-template-columns: 3fr 2fr; gap: 20px; margin-bottom: 24px; }
    .card { background: var(--card); border-radius: 8px; padding: 20px;
            box-shadow: 0 1px 4px rgba(0,0,0,.08); }
    .card h2 { font-size: 1rem; margin-bottom: 12px; color: var(--hdr); }
    table { width: 100%; border-collapse: collapse; font-size: 0.85rem; }
    th { background: var(--hdr); color: #fff; padding: 8px 10px; text-align: left; position: sticky; top: 0; }
    td { padding: 7px 10px; border-bottom: 1px solid #eee; vertical-align: top; }
    tr:hover td { background: rgba(0,0,0,.02); }
    .triage-badge { display: inline-block; padding: 2px 8px; border-radius: 4px;
                    font-size: 0.75rem; font-weight: bold; }
    .pill { display: inline-block; background: #eef; border-radius: 10px;
            padding: 1px 6px; font-size: 0.7rem; margin: 1px; }
    a { color: #1a6bb5; text-decoration: none; }
    a:hover { text-decoration: underline; }
    .preprint { color: #c0392b; font-size: 0.7rem; font-weight: bold; }
    canvas { max-height: 320px; }
  </style>
</head>
<body>
<header>
  <h1>🔭 Horizon Scanning Brief — {{ run_date }}</h1>
  <p>Profile: {{ run_meta.profile_name }} · Run {{ run_meta.run_id }} · {{ paired | length }} items</p>
</header>

<div class="container">

  <!-- Triage summary -->
  <div class="summary-grid">
    {% set triage_cfg = [
      ("Act Now",       "🔴", "var(--act-now)"),
      ("Watch",         "🟠", "var(--watch)"),
      ("Monitor",       "🟡", "var(--monitor)"),
      ("For Awareness", "🟢", "var(--awareness)"),
      ("Low Signal",    "⚪", "var(--low)"),
    ] %}
    {% for level, emoji, colour in triage_cfg %}
    <div class="metric-card" style="border-top: 4px solid {{ colour }}">
      <div class="num">{{ triage_counts.get(level, 0) }}</div>
      <div class="lbl">{{ emoji }} {{ level }}</div>
    </div>
    {% endfor %}
  </div>

  <!-- Chart + Domain breakdown -->
  <div class="two-col">
    <div class="card">
      <h2>Evidence Strength vs Clinical Impact</h2>
      <canvas id="scatterChart"></canvas>
    </div>
    <div class="card">
      <h2>Domain Breakdown</h2>
      <table>
        <tr><th>Domain</th><th>Items</th></tr>
        {% for domain, count in domain_counts.items() %}
        <tr><td>{{ domain }}</td><td>{{ count }}</td></tr>
        {% endfor %}
      </table>
    </div>
  </div>

  <!-- Full item list -->
  <div class="card">
    <h2>All Items ({{ paired | length }}, by score)</h2>
    <div style="overflow-x:auto; max-height:600px; overflow-y:auto;">
    <table>
      <thead>
        <tr>
          <th>Triage</th><th>Title</th><th>Source</th>
          <th>Published</th><th>Score</th><th>A</th><th>B</th><th>C</th><th>D</th>
          <th>Domains</th><th>Action</th>
        </tr>
      </thead>
      <tbody>
      {% for sc, item in paired %}
      <tr>
        <td>
          <span class="triage-badge"
            style="background:{{ triage_colours.get(sc.triage_level, '#eee') }}">
            {{ sc.triage_emoji }} {{ sc.triage_level }}
          </span>
        </td>
        <td>
          <a href="{{ item.url }}" target="_blank">{{ item.title[:100] }}</a>
          {% if item.is_preprint %}<br><span class="preprint">⚠ PREPRINT</span>{% endif %}
          <br><small>{{ sc.annotation[:120] }}…</small>
        </td>
        <td>{{ item.source_name[:30] }}</td>
        <td>{{ item.published_date }}</td>
        <td><strong>{{ sc.composite_score }}</strong></td>
        <td>{{ sc.evidence_strength }}</td>
        <td>{{ sc.clinical_impact }}</td>
        <td>{{ sc.insurance_readiness }}</td>
        <td>{{ sc.domain_relevance }}</td>
        <td>
          {% for d in item.domains %}<span class="pill">{{ d }}</span>{% endfor %}
          <br><span style="font-size:.7rem;opacity:.6">{{ item.horizon_tier }}</span>
        </td>
        <td style="font-size:.78rem">{{ sc.suggested_action }}</td>
      </tr>
      {% endfor %}
      </tbody>
    </table>
    </div>
  </div>

</div>

<script>
(function() {
  var data = {{ scatter_json | safe }};
  var colourMap = {{ triage_colours | tojson }};
  var datasets = {};
  data.forEach(function(p) {
    if (!datasets[p.triage]) datasets[p.triage] = { label: p.triage, data: [],
      backgroundColor: p.colour + 'cc', pointRadius: 7 };
    datasets[p.triage].data.push({ x: p.x, y: p.y, label: p.label });
  });
  new Chart(document.getElementById('scatterChart'), {
    type: 'scatter',
    data: { datasets: Object.values(datasets) },
    options: {
      responsive: true,
      plugins: { tooltip: { callbacks: {
        label: function(ctx) { return ctx.raw.label + ' (' + ctx.raw.x + ', ' + ctx.raw.y + ')'; }
      }}},
      scales: {
        x: { title: { display: true, text: 'Evidence Strength (A)' }, min: 0, max: 100 },
        y: { title: { display: true, text: 'Clinical Impact (B)' },    min: 0, max: 100 },
      }
    }
  });
})();
</script>
</body>
</html>
